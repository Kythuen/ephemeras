{
  "root": true,
  "env": {
    "es2021": true,
    "node": true
  },
  "extends": [
    "airbnb-base",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "parser": "@typescript-eslint/parser"
  },
  "ignorePatterns": [
    "node_modules/",
    ".vscode/",
    "dist/",
    "public/",
    "vite.config.ts",
    "*.d.ts"
  ],
  "rules": {
    "import/order": 0,
    "import/no-unresolved": 0,
    "import/extensions": 0,
    "func-names": [
      "warn",
      "never"
    ],
    "import/prefer-default-export": 0,
    "no-restricted-syntax": 0,
    "default-case": 0,
    "import/no-extraneous-dependencies": 0,
    "@typescript-eslint/no-unused-vars": [
      2
    ],
    "lines-between-class-members": 0,
    "guard-for-in": 0,
    "no-continue": 0,
    "no-new": 0,
    "consistent-return": 0,
    "no-unused-expressions": 0,
    "no-await-in-loop": 0,
    "no-console": 0,
    "no-param-reassign": 0
  },
  "plugins": [
    "@typescript-eslint"
  ]
}