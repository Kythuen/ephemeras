{
  "name": "@ephemeras/utils",
  "version": "2.3.2",
  "description": "Utils for ephemeras",
  "keywords": [
    "ephemeras",
    "utils"
  ],
  "author": {
    "name": "ephemeras",
    "email": "ephemeras@qq.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "dev": "tsup --watch src",
    "build": "tsup",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bundle-require": "^4.0.1",
    "joi": "^17.10.2",
    "minimatch": "^9.0.3",
    "prettier": "3.2.5"
  },
  "optionalDependencies": {
    "@iarna/toml": "^2.2.5",
    "ini": "^4.1.0",
    "js-yaml": "^4.1.0",
    "yaml": "^2.2.1"
  },
  "devDependencies": {
    "@types/ini": "^1.3.31",
    "@types/js-yaml": "^4.0.5",
    "@types/prettier": "^2.7.2"
  }
}
